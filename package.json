{
  "name": "@sorostream/sdk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/react",
    "packages/cli"
  ],
  "description": "TypeScript SDK for the SoroStream payment streaming protocol on Stellar Soroban",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wallets": {
      "import": "./dist/wallets.mjs",
      "require": "./dist/wallets.js",
      "types": "./dist/wallets.d.ts"
    },
    "./mock": {
      "import": "./dist/mock.mjs",
      "require": "./dist/mock.js",
      "types": "./dist/mock.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/wallets.ts src/mock.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "build:all": "npm run build && npm run build -w packages/react && npm run build -w packages/cli"
  },
  "keywords": [
    "stellar",
    "soroban",
    "streaming",
    "payments",
    "usdc",
    "web3"
  ],
  "license": "MIT",
  "dependencies": {
    "@stellar/freighter-api": "^3.0.0",
    "@stellar/stellar-sdk": "^13.0.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SoroStream/sorostream-sdk.git"
  }
}
