{
  "name": "@sorostream/react",
  "version": "0.1.0",
  "description": "React hooks for the SoroStream payment streaming protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "lint": "tsc --noEmit"
  },
  "keywords": ["stellar", "soroban", "streaming", "payments", "react", "hooks"],
  "license": "MIT",
  "peerDependencies": {
    "@sorostream/sdk": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/SoroStream/sorostream-sdk.git"
  }
}
